ORG 2EA
arr_first_elem: WORD 0x0300
arr_last_elem: WORD 0xA000
arr_length: WORD 0x4000
result: WORD 0x0280
START:
    CLA
    ST result
    LD #5
    ST arr_length
    LD arr_first_elem
    ST arr_last_elem
    repeat: LD (arr_last_elem)+
    BEQ is_z_1
    CLC
    CMC
    is_z_1: CLA
    NOT
    AND result
    ROL
    ST result  ; result = result * 2 + 1 if result != 0
    LOOP $arr_length
    JUMP repeat
    HLT

arr: WORD 0xF600, 0x0000, 0xF700, 0x0000, 0x0000