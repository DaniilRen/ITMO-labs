<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.gui.controllers.AuthController"
            styleClass="auth-container"
            prefWidth="520"
            prefHeight="380">

    <stylesheets>
        <URL value="@/css/style.css"/>
    </stylesheets>

    <top>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="0" left="12"/>
            </padding>
            <VBox spacing="2" alignment="CENTER_RIGHT">
                <Label fx:id="serverStatusLabel" styleClass="status-connected"/>
                <Label fx:id="syncStatusLabel" styleClass="status-sync"/>
            </VBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" alignment="CENTER">
            <Label fx:id="welcomeLabel" styleClass="title-label"/>
            <TextField fx:id="usernameField" styleClass="text-field" maxWidth="280"/>
            <PasswordField fx:id="passwordField" styleClass="password-field" maxWidth="280"/>
            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="registerButton" styleClass="accent-button" prefWidth="130" onAction="#handleRegister"/>
                <Button fx:id="loginButton" styleClass="secondary-dark-button" prefWidth="130" onAction="#handleLogin"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="10" right="12" bottom="12" left="12"/>
            </padding>
            <Button fx:id="languageButton" styleClass="language-button" onAction="#handleLanguage"/>
        </HBox>
    </bottom>

</BorderPane>
