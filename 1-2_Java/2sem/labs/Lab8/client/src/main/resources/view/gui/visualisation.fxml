<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.gui.controllers.VisualisationController"
            styleClass="vis-container"
            prefWidth="900"
            prefHeight="700">

    <stylesheets>
        <URL value="@/css/style.css"/>
    </stylesheets>

    <top>
        <HBox styleClass="top-bar" spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button fx:id="backButton" styleClass="primary-button" onAction="#handleBack"/>
						<Button styleClass="primary-button" text="Обновить объекты" onAction="#handleSyncObjects"/>
            <Label fx:id="titleLabel" styleClass="title-label"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="canvasPane" styleClass="canvas-pane" minWidth="860" minHeight="600">
            <Canvas fx:id="canvas" width="860" height="600"/>
        </StackPane>
    </center>

</BorderPane>
