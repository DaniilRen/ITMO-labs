<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.gui.VisualisationController"
            styleClass="vis-container"
            prefWidth="800"
            prefHeight="600">

    <stylesheets>
        <URL value="@/css/style.css"/>
    </stylesheets>

    <top>
        <HBox styleClass="top-bar" spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="← Back to Home" onAction="#handleBack" styleClass="primary-button"/>
            <Label text="Visualisation" styleClass="title-label" HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <Label text="Visualisation Window" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Visualisation content will be implemented here" style="-fx-font-size: 14px;"/>
            <Label text="(Chart, graph, or diagram visualization)" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </center>

</BorderPane>