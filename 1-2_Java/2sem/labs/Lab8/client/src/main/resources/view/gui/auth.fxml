<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="view.gui.AuthController"
      styleClass="auth-container"
      spacing="15"
      alignment="CENTER"
      prefWidth="350"
      prefHeight="400">

    <stylesheets>
        <URL value="@/css/style.css"/>
    </stylesheets>

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Authorization" styleClass="title-label"/>
    
    <TextField fx:id="usernameField" promptText="Username" styleClass="text-field" maxWidth="250"/>
    
    <PasswordField fx:id="passwordField" promptText="Password" styleClass="password-field" maxWidth="250"/>
    
    <Label fx:id="errorLabel" styleClass="error-label" text=""/>
    
    <Button fx:id="loginButton" text="Login" styleClass="primary-button" maxWidth="250" onAction="#handleLogin"/>
    
    <Button text="Register" styleClass="secondary-button" maxWidth="250" onAction="#handleRegister"/>

</VBox>